{
  "$defs": {
    "PackContext": {
      "additionalProperties": true,
      "description": "Context payload shared by slides.\n\nExtra keys are allowed so packs can continue to pass arbitrary template values.",
      "properties": {
        "metrics": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/PackMetricBinding"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional metric bindings resolved into Jinja variables.",
          "title": "Metrics"
        }
      },
      "title": "PackContext",
      "type": "object"
    },
    "PackMetricBinding": {
      "additionalProperties": false,
      "description": "Binding describing how a metric value becomes a Jinja variable.\n\nBindings may reference a catalogue metric (`key` + optional `variant`) or declare an\narithmetic `expression` over other metrics/aliases. When `alias` is omitted it is\nderived from the full metric key by replacing dots with underscores.",
      "properties": {
        "key": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Catalogue metric key (e.g., documents_verified) or dotted variant key.",
          "title": "Key"
        },
        "alias": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Jinja-safe variable name exposed to templates.",
          "title": "Alias"
        },
        "variant": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional variant path appended to `key` when `key` is not dotted.",
          "title": "Variant"
        },
        "calculate": {
          "description": "Optional extra DAX CALCULATE predicates for this binding.",
          "items": {
            "type": "string"
          },
          "title": "Calculate",
          "type": "array"
        },
        "format": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional formatting hint mirroring Praeparo format tokens.",
          "title": "Format"
        },
        "expression": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional arithmetic expression referencing metric keys or aliases.",
          "title": "Expression"
        },
        "override": {
          "default": false,
          "description": "True when intentionally shadowing an inherited alias.",
          "title": "Override",
          "type": "boolean"
        }
      },
      "title": "PackMetricBinding",
      "type": "object"
    },
    "PackPlaceholder": {
      "additionalProperties": false,
      "description": "Placeholder binding used by PPTX assembly.",
      "properties": {
        "visual": {
          "anyOf": [
            {
              "$ref": "#/$defs/PackVisualRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Visual rendered for this placeholder."
        },
        "image": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional static image path for this placeholder, relative to the pack file.",
          "title": "Image"
        },
        "text": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Plain text (optionally templated) injected into a named text shape.",
          "title": "Text"
        }
      },
      "title": "PackPlaceholder",
      "type": "object"
    },
    "PackSlide": {
      "additionalProperties": false,
      "description": "Single slide within a pack.",
      "properties": {
        "title": {
          "description": "Human-friendly slide title.",
          "title": "Title",
          "type": "string"
        },
        "id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional stable identifier for the slide.",
          "title": "Id"
        },
        "context": {
          "anyOf": [
            {
              "$ref": "#/$defs/PackSlideContext"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional template context merged with the pack-level context."
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Free-form notes for authors/reviewers.",
          "title": "Notes"
        },
        "visual": {
          "anyOf": [
            {
              "$ref": "#/$defs/PackVisualRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional visual reference; absent for non-visual slides."
        },
        "template": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional PPTX template identifier (TEMPLATE_TAG) used during deck assembly.",
          "title": "Template"
        },
        "placeholders": {
          "anyOf": [
            {
              "additionalProperties": {
                "$ref": "#/$defs/PackPlaceholder"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional placeholder map when a slide template contains multiple picture placeholders.",
          "title": "Placeholders"
        },
        "image": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional static image path when using a PPTX template without a visual.",
          "title": "Image"
        }
      },
      "required": [
        "title"
      ],
      "title": "PackSlide",
      "type": "object"
    },
    "PackSlideContext": {
      "additionalProperties": true,
      "description": "Context payload specific to an individual slide.",
      "properties": {
        "metrics": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/PackMetricBinding"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional metric bindings resolved into Jinja variables.",
          "title": "Metrics"
        }
      },
      "title": "PackSlideContext",
      "type": "object"
    },
    "PackVisualRef": {
      "additionalProperties": true,
      "description": "Reference to a visual or an inline visual config plus optional slide-level overrides.",
      "properties": {
        "ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional path to the visual definition relative to the pack file.",
          "title": "Ref"
        },
        "type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional inline visual type or Python module path when embedding a config directly.",
          "title": "Type"
        },
        "filters": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional OData filters applied on top of pack-level defaults.",
          "title": "Filters"
        },
        "calculate": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional DAX filters applied on top of pack-level defaults.",
          "title": "Calculate"
        }
      },
      "title": "PackVisualRef",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Root configuration for a pack composed of slides.",
  "properties": {
    "schema": {
      "description": "Schema or contract identifier for the pack.",
      "title": "Schema",
      "type": "string"
    },
    "context": {
      "$ref": "#/$defs/PackContext",
      "description": "Template context shared by slides."
    },
    "define": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Optional DAX DEFINE block applied to DAX-backed visuals.",
      "title": "Define"
    },
    "calculate": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Pack-level DAX filters applied to DAX-backed visuals.",
      "title": "Calculate"
    },
    "filters": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Pack-level OData filters applied to Power BI visuals.",
      "title": "Filters"
    },
    "slides": {
      "description": "Ordered slide definitions.",
      "items": {
        "$ref": "#/$defs/PackSlide"
      },
      "title": "Slides",
      "type": "array"
    }
  },
  "required": [
    "schema"
  ],
  "title": "PackConfig",
  "type": "object"
}